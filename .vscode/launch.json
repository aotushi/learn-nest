{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "L7 index.js: launch",
      "program": "${workspaceFolder}/L7/index.js",
      "cwd": "${workspaceFolder}/L7",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "stopOnEntry": true
    },
    {
      "type": "node",
      "request": "launch",
      "name": "L7 my-app: launch Nest debug",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["start:debug"],
      "cwd": "${workspaceFolder}/L7/my-app",
      "console": "integratedTerminal",
      "restart": true,
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**"],
      "stopOnEntry": true
    },
    {
      "type": "node",
      "request": "attach",
      "name": "L7 my-app: attach 9229",
      "port": 9229,
      "restart": true,
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "L8",
      "cwd": "${workspaceFolder}/L8/custom-provider",
      "runtimeExecutable": "pnpm",
      "args": ["start:dev"],
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal"
    }
  ]
}
